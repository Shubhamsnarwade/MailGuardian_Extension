# MailGuardian Server - Environment Variables
# Rename this file to .env and fill in your values

# MongoDB connection string (local)
MONGODB_URI=mongodb://localhost:27017/mailguardian

# Your Gemini API Key (only YOU need this - users never see it)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret for admin authentication (make this a long random string)
JWT_SECRET=mailguardian_super_secret_key_change_this_in_production

# Server port
PORT=5000

# Super Admin credentials (first time setup)
SUPER_ADMIN_EMAIL=superadmin@mailguardian.com
SUPER_ADMIN_PASSWORD=super@123
